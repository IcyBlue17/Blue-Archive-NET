# 站点显示名（侧栏、登录页、浏览器标题）；不设则默认 Blue Archive
# VITE_APP_NAME=Blue Archive

VITE_AQUA_HOST=http://127.0.0.1:8080
# 官方静态数据（与 aquaNet `.env` 一致）；自建 CDN 时可改掉
VITE_DATA_HOST=https://aquadx.net
# 图片签名开关；on 后图片统一改走 `/_img?u=...`
# 本地 Vite dev 默认忽略签名代理；如需本地联调可再开 VITE_IMAGE_SIGN_DEV=on
# VITE_IMAGE_SIGNING=off
# VITE_IMAGE_SIGN_DEV=off
# VITE_IMAGE_SIGN_PATH=/_img
VITE_AQUA_CONNECTION=your.server:port
VITE_TURNSTILE_SITE_KEY=
VITE_DISCORD_INVITE=
VITE_TELEGRAM_INVITE=
VITE_QQ_INVITE=
VITE_GITHUB_REPOSITORY=

# 下面这些是部署平台上的服务端函数环境变量，不要写成 VITE_ 前缀
# IMAGE_SIGN_ALLOW_HOSTS=blue-archive.icybit.cn,aquadx.net,aqua.icybit.cn
# IMAGE_SIGN_AWS_HOSTS=img.example.com
# IMAGE_SIGN_AWS_ACCESS_KEY_ID=
# IMAGE_SIGN_AWS_SECRET_ACCESS_KEY=
# IMAGE_SIGN_AWS_SESSION_TOKEN=
# IMAGE_SIGN_AWS_REGION=ap-shanghai
# IMAGE_SIGN_AWS_SERVICE=s3
