# 站点显示名（侧栏、登录页、浏览器标题）；不设则默认 Blue Archive
# VITE_APP_NAME=Blue Archive

VITE_AQUA_HOST=http://127.0.0.1:8080
# 官方静态数据（与 aquaNet `.env` 一致）；自建 CDN 时可改掉
VITE_DATA_HOST=https://aquadx.net
# 图片单独迁移到对象存储/CDN 后可设置独立图片域名
# VITE_IMAGE_HOST=https://img.example.com
# CHUNITHM 静态资源子目录，默认留空；如需 `/chu3-assets` 再手动填写
# VITE_CHU3_ASSET_BASE=
# 可选：打开后，静态图片仍直接请求 IMAGE_HOST，但会：
# 1. 把本地 JWT 同步成浏览器 cookie
# 2. 对跨域图片请求显式带 credentials
# 注意：若站点是 blue-archive.icybit.cn，图片域名是 img.icybit.cn，
#       这里应填共享父域 `.icybit.cn`
# VITE_IMAGE_AUTH=off
# VITE_IMAGE_COOKIE_DOMAIN=.example.com
# VITE_IMAGE_COOKIE_NAME=aqua_jwt
# VITE_IMAGE_COOKIE_PATH=/
# VITE_IMAGE_COOKIE_SAMESITE=None
# VITE_IMAGE_COOKIE_SECURE=on
# VITE_IMAGE_COOKIE_MAX_AGE=604800
VITE_AQUA_CONNECTION=your.server:port
VITE_TURNSTILE_SITE_KEY=
VITE_DISCORD_INVITE=
VITE_TELEGRAM_INVITE=
VITE_QQ_INVITE=
VITE_GITHUB_REPOSITORY=
