# 站点显示名（侧栏、登录页、浏览器标题）；不设则默认 Blue Archive
# VITE_APP_NAME=Blue Archive

VITE_AQUA_HOST=http://127.0.0.1:8080
# 官方静态数据（与 aquaNet `.env` 一致）；自建 CDN 时可改掉
VITE_DATA_HOST=https://aquadx.net
# 图片单独迁移到对象存储/CDN 后可设置独立图片域名
# VITE_IMAGE_HOST=https://img.example.com
# EdgeOne Token 鉴权 Method A：token=timestamp-rand-uid-md5
# 这里只是前端伪签名，真正校验在 EdgeOne
# VITE_IMAGE_SIGNING=off
# VITE_IMAGE_SIGN_PARAM=token
# VITE_IMAGE_SIGN_KEY=
# VITE_IMAGE_SIGN_UID=0
# VITE_IMAGE_SIGN_RAND_LEN=12
VITE_AQUA_CONNECTION=your.server:port
VITE_TURNSTILE_SITE_KEY=
VITE_DISCORD_INVITE=
VITE_TELEGRAM_INVITE=
VITE_QQ_INVITE=
VITE_GITHUB_REPOSITORY=
