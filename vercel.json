{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "installCommand": "bun install",
  "buildCommand": "bun run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/_img",
      "destination": "/api/img-sign"
    },
    {
      "source": "/api/:path*",
      "destination": "https://aqua.icybit.cn/api/:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "https://aqua.icybit.cn/uploads/:path*"
    },
    {
      "source": "/d/:path*",
      "destination": "https://aqua.icybit.cn/d/:path*"
    },
    {
      "source": "/((?!api/|uploads/|d/|.*\\..*).*)",
      "destination": "/"
    }
  ]
}
